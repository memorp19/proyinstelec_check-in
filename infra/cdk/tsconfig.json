{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "declaration": true,
    "inlineSources": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist", "cdk.out"]
}
