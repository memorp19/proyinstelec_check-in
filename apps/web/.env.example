# Google OAuth — obtener en console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth — generar con: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# DynamoDB local (omitir en prod — usa credenciales IAM del entorno AWS)
DYNAMODB_ENDPOINT=http://localhost:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# Nombres de tablas (CDK outputs — copiar tras cdk deploy)
USERS_TABLE=proyinstelec-users
INVITACIONES_TABLE=proyinstelec-invitaciones
MAIN_TABLE=proyinstelec-main
ODOO_QUEUE_TABLE=proyinstelec-odoo-queue

# Google Drive service account (ver docs/setup-google-drive.md)
# En prod: almacenados en SSM — no se usan estas vars directamente
DRIVE_SERVICE_ACCOUNT_EMAIL=field-app-storage@tu-proyecto.iam.gserviceaccount.com
DRIVE_SERVICE_ACCOUNT_KEY={"type":"service_account","client_email":"...","private_key":"..."}
DRIVE_ROOT_FOLDER_ID=1BxiMYour_Folder_ID_Here

# SSM parameter paths (leídos por drive.ts y odoo.ts en Lambda)
DRIVE_SERVICE_ACCOUNT_EMAIL_PARAM=/proyinstelec/drive/service-account-email
DRIVE_SERVICE_ACCOUNT_KEY_PARAM=/proyinstelec/drive/service-account-key
DRIVE_ROOT_FOLDER_ID_PARAM=/proyinstelec/drive/root-folder-id
ODOO_URL_PARAM=/proyinstelec/odoo/url
ODOO_DB_PARAM=/proyinstelec/odoo/db
ODOO_API_KEY_PARAM=/proyinstelec/odoo/api-key

# Odoo sync (true solo en prod y cuando el deploy de Odoo está listo)
ODOO_SYNC_ENABLED=false

# CloudFront (CDK output)
CLOUDFRONT_DISTRIBUTION_ID=
